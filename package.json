{
  "name": "guardian-road",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "smoke:api": "node scripts/smoke-api-arc.mjs",
    "smoke:api:errors": "node scripts/smoke-api-errors.mjs",
    "smoke:report": "node scripts/smoke-report-export.mjs",
    "smoke:yolo": "node scripts/smoke-yolo-detect.mjs",
    "smoke:mobile": "node scripts/smoke-mobile-capture.mjs",
    "smoke:pages": "node scripts/smoke-pages.mjs",
    "smoke:mobile-config": "node scripts/smoke-mobile-config.mjs",
    "demo:doctor": "node scripts/demo-doctor.mjs",
    "scenarios:generate": "node scripts/generate-road-scenarios.mjs",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:typecheck": "npm --prefix apps/mobile run typecheck",
    "sim": "npm --prefix apps/mobile run start -- --lan",
    "expo": "npm exec --prefix apps/mobile -- expo"
