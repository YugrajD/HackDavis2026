    "react-dom": "^19.0.0",
    "three": "^0.180.0",
    "@react-three/fiber": "^9.1.2",
    "@react-three/drei": "^10.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.21",
